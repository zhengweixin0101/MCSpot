# ========== 腾讯云配置 ==========
# 从腾讯云控制台获取 https://console.cloud.tencent.com/cam/capi
TENCENT_SECRET_ID=your_secret_id_here
TENCENT_SECRET_KEY=your_secret_key_here

# 云服务器所在地域，例如 ap-shanghai, ap-beijing 等
# 完整列表：https://cloud.tencent.com/document/api/213/15692#.E5.9C.B0.E5.9F.9F.E5.88.97.E8.A1.A8
TENCENT_REGION=ap-shanghai

# ========== 服务器配置 ==========
# Express 服务器监听端口
PORT=3000

# ========== Redis 配置 ==========
# Redis 连接地址（用于存储操作日志和认证记录）
REDIS_URL=redis://localhost:6379
# Redis 密码（如果 Redis 连接字符串中已包含密码，此项可留空）
REDIS_PASSWORD=

# ========== 认证配置 ==========
# JSON 格式，用户名和密码配置
# 用户名唯一，密码用于认证，permissions 为权限数组
# 所有 API 请求必须使用 Authorization: Bearer <username>:<password> 格式进行认证
# 权限说明：
#   - admin: 管理员，拥有所有权限
#   - run_instance: 创建从模板创建实例
#   - terminate_instance: 删除实例
#   - read_instance: 查看实例信息
AUTH_PASSWORDS={"admin": {"password": "Admin@abc123456!", "permissions": ["admin"]}, "operator": {"password": "Operator@123456", "permissions": ["run_instance", "terminate_instance", "read_instance"]}, "viewer": {"password": "Viewer@123456", "permissions": ["read_instance"]}}

# 密码错误尝试次数限制（超过此次数 IP 被锁定 15 分钟）
MAX_AUTH_ATTEMPTS=5

# ========== Minecraft 配置 ==========
# 启动模板 ID（从腾讯云控制台创建）
# https://console.cloud.tencent.com/cvm/template
MC_LAUNCH_TEMPLATE_ID=lt-xxxxxx
MC_LAUNCH_TEMPLATE_VERSION=1 # 启动模板版本，可选，未填此项时使用默认版本

# Minecraft 服务器端口
MC_PORT=25565

# Minecraft 游戏版本（用于提示玩家）
MC_VERSION=Java 1.21.11

# ========== SSH 配置 ==========
# 用于远程执行服务器脚本
SSH_PORT=22
SSH_USERNAME=root

# SSH 认证方式 (优先级: PRIVATE_KEY > PRIVATE_KEY_PATH > PASSWORD)
# 方式1: 直接在环境变量中配置私钥内容 (推荐，更安全，无需上传文件)
# 注意：如果是单行格式，请将换行符替换为 \n
SSH_PRIVATE_KEY="-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----"

# 方式2: 指定私钥文件路径
SSH_PRIVATE_KEY_PATH=/path/to/private/key

# 方式3: 使用密码
SSH_PASSWORD=your_ssh_password

# 远程脚本目录
# 系统将在此目录下查找 .sh 脚本文件
REMOTE_SCRIPT_PATH=/opt

# ========== 对象存储配置 ==========
# 存储类型: cos 或 s3
STORAGE_TYPE=cos

# COS 配置 (当 STORAGE_TYPE=cos 时)
# 默认复用 TENCENT_SECRET_ID/KEY
COS_BUCKET=bucket
COS_REGION=ap-shanghai
COS_PREFIX=mc/

# S3 配置 (当 STORAGE_TYPE=s3 时)
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_ENDPOINT=https://s3.example.com
S3_BUCKET=your_bucket
S3_REGION=auto
S3_PREFIX=mc/