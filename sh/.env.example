# 将此文件部署到服务器的 /opt/.env

# Minecraft 服务端目录
export MCS_DIR="/opt/mcs"

# Minecraft 服务端 JAR 文件名
export MC_JAR="1.21.11-server.jar"

# 存储方式选择: s3 或 cos
export STORAGE_TYPE="cos"

# S3 存储配置 (当 STORAGE_TYPE=s3 时使用)
# 使用 aws configure 命令配置 AWS CLI
export S3_ENDPOINT="https://s3.example.com"
export S3_BUCKET="bucket"

# 腾讯云 COS 配置 (当 STORAGE_TYPE=cos 时使用)
# 使用 coscli config init 命令配置 COSCLI
export COS_BUCKET_ALIAS="mcspot"  # COS 存储桶别名

# API 配置
# 部署的 MCSpot 访问地址
export API_BASE="https://mcspot.example.com"

# 接口认证信息
# MCSpot 登录信息，格式为 "<用户名>:<密码>"
export AUTH_CREDENTIALS="username:password"

# 自动关闭脚本配置
export AUTO_SHUTDOWN="/opt/auto_shutdown.sh"
export AUTO_SHUTDOWN_LOG="/opt/auto_shutdown.log"

# screen 会话名称
export SCREEN_NAME="mcserver"

# Java 内存配置
export JAVA_MIN_MEM="2G"
export JAVA_MAX_MEM="3G"
