# 将此文件及其它sh上传到服务器的 /opt/.env
# 建议在服务器新建一个同名文件，将文件内容复制到新建的文件中，以防莫名其妙的错误。

# Minecraft 服务端目录
export MCS_DIR="/opt/mcs"
# Minecraft 服务端目录下的服务端 JAR 文件名
export MC_JAR="server.jar"
# screen 会话名称
export SCREEN_NAME="mcserver"

# Minecraft 服务端启动命令
# "-Xms2G": 最小内存
# "-Xmx3G": 最大内存
# "$MC_JAR_PATH": 服务端 JAR 文件路径（脚本会自动注入此变量）
# 注意：使用单引号以防止在 .env 加载时变量被提前展开
export MCS_START_COMMAND='java -Xms2G -Xmx3G -jar "$MC_JAR_PATH" nogui'

# 自动关闭脚本配置
export AUTO_SHUTDOWN="/opt/sh/auto_shutdown.sh"
export AUTO_SHUTDOWN_LOG="/opt/sh/tmp/auto_shutdown.log"
# 自动关机检测配置
export IDLE_THRESHOLD="5"       # 连续空闲检测次数阈值
export CHECK_INTERVAL="120"     # 每次检测间隔（秒）

# API 配置
# MCSpot 访问地址
export API_BASE="https://mcspot.example.com"
# MCSpot 登录信息（需要 terminate_instance 权限）
export AUTH_USERNAME="username"
export AUTH_PASSWORD="password"

# 备份配置文件列表（需要备份的除world文件夹外的同目录配置文件，空格分隔，不设置则使用默认列表）
export CONFIG_FILES="server.properties eula.txt ops.json whitelist.json banned-players.json banned-ips.json usercache.json"

# 存储方式选择: s3 或 cos，需先安装并配置对应的cli工具
export STORAGE_TYPE="cos"

# S3 存储配置 (当 STORAGE_TYPE=s3 时使用)
# 使用 aws configure 命令配置 AWS CLI
export S3_ENDPOINT="https://s3.example.com" # S3 端点
export S3_BUCKET="bucket"   # S3 存储桶名称

# 腾讯云 COS 配置 (当 STORAGE_TYPE=cos 时使用)
# 使用 coscli config init 命令配置 COSCLI
export COS_BUCKET_ALIAS="mcspot"  # COS 存储桶别名